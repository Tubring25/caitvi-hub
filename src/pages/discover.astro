---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FicDiscovery from '@/components/react/FicDiscovery';

const title = "Discover - CaitVi Hub";
---

<BaseLayout title={title} description="Browse our curated collection of CaitVi fan fiction — sorted by spice, angst, and everything in between.">
  <main class="w-full discover-background pt-28">
    <section class="w-full max-w-7xl mx-auto px-5 sm:px-8 lg:px-10 py-12 md:py-16 text-center">
      <h1 class="text-[clamp(2rem,4vw+1rem,3rem)] font-serif font-bold tracking-wide text-white mb-3">
        Discover
      </h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Browse our curated collection of CaitVi fan fiction.
      </p>
    </section>
    <FicDiscovery client:load />
  </main>
</BaseLayout>

<style>
  .discover-background {
    position: relative;
    width: 100%;
    min-height: 100vh;
  }

  .discover-background::before {
    content: '';
    position: fixed;
    top: -50px;
    left: -50px;
    right: -50px;
    bottom: -50px;
    background-image: url('/images/home_bg_back.jpeg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(30px) brightness(0.5) saturate(1.4);
    will-change: transform;
    transform: translateZ(0);
    z-index: -2;
  }
</style>
