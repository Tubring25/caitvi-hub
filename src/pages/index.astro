---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QuoteDisplay from '@/components/react/QuoteDisplay';
import FicDiscovery from '@/components/react/FicDiscovery';

const title = "Piltover's Finest";
---

<BaseLayout title={title} description="A curated sanctuary for CaitVi fan fiction — discover the finest stories about Caitlyn & Vi from Arcane.">
  <main class="w-full homepage-background">
    <section class="relative h-screen w-full overflow-hidden">
      <img
        src="/images/home_bg_front.jpeg"
        alt="Caitlyn and Vi"
        class="absolute inset-0 w-full h-full object-cover object-left"
      />

      {/* Bottom gradient overlay */}
      <div class="hero-overlay absolute inset-0 z-[1]" aria-hidden="true"></div>

      {/* Text content anchored to bottom */}
      <div class="absolute inset-x-0 bottom-0 z-10 pb-24 sm:pb-20 px-5 sm:px-8 lg:px-10">
        <div class="max-w-7xl mx-auto hero-content">

          <span class="inline-block text-[10px] sm:text-[11px] uppercase tracking-[0.5em] text-white/50 font-sans font-medium mb-3 sm:mb-5">
            Caitlyn × Vi
          </span>

          <h1 class="font-decorative text-[clamp(1.8rem,5vw+0.5rem,5.5rem)] leading-[1] sm:leading-[0.95] tracking-wide text-white mb-4 sm:mb-6">
            Piltover&apos;s Finest
          </h1>

          <div class="w-12 sm:w-16 h-[1.5px] bg-gradient-to-r from-[#D52D00] via-[#D462A6] to-[#A30262] mb-4 sm:mb-6 opacity-70" aria-hidden="true"></div>

          <div class="max-w-md">
            <QuoteDisplay client:load />
          </div>

        </div>
      </div>


    </section>
    <FicDiscovery client:load />
  </main>
</BaseLayout>

<style>
  .hero-overlay {
    background: linear-gradient(
      to top,
      rgba(10, 6, 8, 0.95) 0%,
      rgba(10, 6, 8, 0.7) 25%,
      rgba(10, 6, 8, 0.2) 50%,
      transparent 70%
    );
  }

  .hero-content {
    animation: heroReveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(24px);
  }

  @keyframes heroReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .homepage-background {
    position: relative;
    width: 100%;
  }

  .homepage-background::before {
    content: '';
    position: fixed;
    top: -50px;
    left: -50px;
    right: -50px;
    bottom: -50px;
    background-image: url('/images/home_bg_back.jpeg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(30px) brightness(0.5) saturate(1.4);
    will-change: transform;
    transform: translateZ(0);
    z-index: -2;
  }
</style>
