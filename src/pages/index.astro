---
import '../styles/global.css';
import { ArrowDown, Heart } from "lucide-react";
import QuoteDisplay from '@/components/react/QuoteDisplay';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import FicDiscovery from '@/components/react/FicDiscovery';


const title = "Piltover's Finest";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class="w-full homepage-background pt-28">
      <section class="flex h-[calc(100vh-8rem)] w-11/12 mx-auto flex-col items-center justify-center text-center relative overflow-hidden">
        <img 
          src="/images/home_bg_front.jpeg" 
          alt="Hero background" 
          class="absolute inset-0 w-full h-full object-cover object-left"
        />
        <div class="relative z-10 flex flex-col items-center justify-center mx-auto px-4 w-4/5 animate-fade-in-up">
          
          <h1 class="text-[clamp(3rem,6vw+1rem,6rem)] font-serif font-bold tracking-widest text-white mb-2 drop-shadow-lg">
            Piltover&apos;s Finest
          </h1>

          <div class="text-xl md:text-2xl text-foreground font-semibold mb-2 opacity-90">
            Caitlyn × Vi
          </div>

          <QuoteDisplay client:load />

        </div>
        <ArrowDown className="size-8 text-primary/60 animate-bounce absolute bottom-4 left-1/2 -translate-x-1/2" />
      </section>
      <FicDiscovery client:load />
    </main>
    <Footer />
  </body>
</html>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1.2s ease-in-out forwards;
    opacity: 0;
    transform: translateY(30px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

	.homepage-background {
    position: relative;
    width: 100%;
    min-height: calc(100vh - 8rem);
  }

  .homepage-background::before {
    content: '';
    position: fixed;
    top: -50px;
    left: -50px;
    right: -50px;
    bottom: -50px;
    background-image: url('/images/home_bg_back.jpeg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(30px) brightness(0.5) saturate(1.4);
    z-index: -2;
  }
</style>