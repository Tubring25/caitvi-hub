---
import Header from "@/components/astro/Header.astro";
import { ArrowDown } from "lucide-react";
import '../styles/global.css';

const title = "About - CaitVi Hub";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0a0608] text-white overflow-hidden">

    <Header />

    {/* Main Scroll Container */}
    <main id="scroller" class="h-screen w-full overflow-y-scroll snap-y snap-mandatory scroll-smooth">
      
      {/* --- SECTION 1: HERO --- */}
      <section id="section-hero" class="section-panel h-screen w-full snap-start relative overflow-hidden" data-parallax-type="zoom-out">
        {/* Background Layer */}
        <div class="parallax-bg absolute inset-[-100px] bg-[url('/images/home_bg_back.jpeg')] bg-cover bg-center"></div>
        {/* Bottom gradient overlay — warm tone, matching home hero */}
        <div class="absolute inset-0 hero-overlay"></div>

        {/* Content — bottom-left anchored (HeroEditorial) */}
        <div class="absolute inset-x-0 bottom-0 z-10 pb-24 sm:pb-20 px-5 sm:px-8 lg:px-10">
          <div class="max-w-7xl mx-auto">

            <span class="inline-block text-[10px] sm:text-[11px] uppercase tracking-[0.5em] text-white/50 font-sans font-medium mb-3 sm:mb-5 content-animate" style="--delay: 0.1s">
              About
            </span>

            <h1 class="font-decorative text-[clamp(1.8rem,5vw+0.5rem,5.5rem)] leading-[1] sm:leading-[0.95] tracking-wide text-white mb-4 sm:mb-6 content-animate" style="--delay: 0.2s">
              CaitVi Hub
            </h1>

            <div class="w-12 sm:w-16 h-[1.5px] bg-gradient-to-r from-[#D52D00] via-[#D462A6] to-[#A30262] mb-4 sm:mb-6 opacity-70 content-animate" style="--delay: 0.3s" aria-hidden="true"></div>

            <p class="max-w-lg text-white/60 text-[clamp(0.9rem,1.5vw,1.15rem)] leading-relaxed font-sans content-animate" style="--delay: 0.4s">
              A curated sanctuary for the bond that defies Piltover's laws and Zaun's chaos.
            </p>

          </div>
        </div>

        {/* Scroll hint — unified with home */}
        <div class="absolute bottom-8 sm:bottom-5 left-1/2 -translate-x-1/2 z-10 content-animate" style="--delay: 0.6s">
          <ArrowDown className="size-5 text-white/30 animate-bounce" />
        </div>
      </section>

      {/* --- SECTION 2: ORIGIN STORY --- */}
      <section id="section-origin" class="section-panel h-screen w-full snap-start relative flex items-end overflow-hidden" data-parallax-type="pan-right">
        {/* Background Layer */}
        <div class="parallax-bg absolute inset-[-100px] bg-[url('/images/home_bg_front.jpeg')] bg-cover bg-center"></div>
        {/* Warm gradient overlays — open layout, no glass card */}
        <div class="absolute inset-0 bg-linear-to-r from-[#0a0608]/95 via-[#0a0608]/70 to-[#0a0608]/20"></div>
        <div class="absolute inset-0 bg-linear-to-t from-[#0a0608] via-transparent to-transparent"></div>

        {/* Content — bottom-left anchored, open layout */}
        <div class="absolute inset-x-0 bottom-0 z-10 pb-20 sm:pb-24 px-5 sm:px-8 lg:px-10">
          <div class="max-w-7xl mx-auto">

            <span class="inline-block text-[10px] sm:text-[11px] uppercase tracking-[0.4em] text-[#D462A6]/70 font-sans font-medium mb-4 content-animate" style="--delay: 0.1s">
              Our Origin
            </span>

            <h2 class="text-[clamp(1.8rem,4vw+0.5rem,3.5rem)] font-serif font-bold leading-tight mb-6 sm:mb-8 content-animate" style="--delay: 0.2s">
              More Than Just Ships
            </h2>

            <div class="max-w-xl space-y-5 text-[clamp(0.9rem,1.3vw,1.1rem)] text-white/60 leading-relaxed font-sans content-animate" style="--delay: 0.35s">
              <p>
                It started with a simple obsession. The chemistry between a Piltovian Enforcer and a Zaunite Brawler wasn't just sparks—it was a revolution.
              </p>
              <p>
                CaitVi Hub was built to curate the finest fanworks, creating a space where the "Oil and Water" dynamic is celebrated in all its complexity.
              </p>
            </div>

          </div>
        </div>
      </section>

      {/* --- SECTION 3: OUR PROMISE --- */}
      <section id="section-promise" class="section-panel h-screen w-full snap-start relative flex items-end overflow-hidden" data-parallax-type="pan-left">
        {/* Background Layer */}
        <div class="parallax-bg absolute inset-[-100px] bg-[url('/images/home_bg_front.jpeg')] bg-cover bg-left"></div>
        <div class="absolute inset-0 bg-linear-to-l from-[#0a0608] via-[#0a0608]/80 to-transparent"></div>
        <div class="absolute inset-0 bg-linear-to-t from-[#0a0608] via-transparent to-transparent"></div>

        {/* Giant editorial headline — right side, vertically centered */}
        <div class="absolute top-1/2 right-[5vw] -translate-y-1/2 text-right content-animate z-10 hidden md:block" style="--delay: 0.15s">
          <p class="text-[clamp(0.75rem,1vw,0.875rem)] uppercase tracking-[0.4em] text-[#D462A6]/80 mb-6 font-sans font-semibold">What we promise</p>
          <h2 class="text-[clamp(3rem,7vw,7rem)] font-serif font-black leading-[0.85] tracking-tight text-white/95">
            Not every<br/>fic.<br/><span class="italic text-[#D462A6]">The right<br/>ones.</span>
          </h2>
        </div>

        {/* Mobile headline */}
        <div class="md:hidden absolute top-24 right-5 left-5 text-right content-animate z-10" style="--delay: 0.15s">
          <p class="text-xs uppercase tracking-[0.3em] text-[#D462A6]/80 mb-3 font-sans font-semibold">What we promise</p>
          <h2 class="text-[clamp(2.5rem,12vw,4rem)] font-serif font-black leading-[0.85] tracking-tight text-white/95">
            Not every fic.<br/><span class="italic text-[#D462A6]">The right ones.</span>
          </h2>
        </div>

        {/* Bottom content strip */}
        <div class="relative z-10 w-full px-5 sm:px-8 lg:px-10 pb-20 content-animate" style="--delay: 0.4s">
          
          {/* Divider line */}
          <div class="max-w-7xl mx-auto">
            <div class="w-full h-px bg-white/10 mb-8"></div>

            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
              {/* Body copy */}
              <p class="max-w-md text-[clamp(0.875rem,1.2vw,1.05rem)] leading-relaxed text-white/50 font-sans">
                Slow burns, canon divergence, post-canon healing, sharp banter—curated for quality, linked back to every author. No noise.
              </p>

              {/* CTA */}
              <a 
                href="/" 
                class="group inline-flex items-center gap-4 text-white/90 font-sans text-sm font-semibold uppercase tracking-[0.25em] shrink-0"
              >
                <span>Explore the recs</span>
                <span class="inline-block w-10 h-px bg-white/40 group-hover:w-16 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"></span>
              </a>
            </div>

            {/* Legal */}
            <div class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-[0.65rem] text-white/25 uppercase tracking-wider font-sans">
              <span>Fan-made · No files hosted</span>
              <span>Metadata via <a href="https://archiveofourown.org/" class="hover:text-white/50 transition-colors">AO3</a></span>
              <span>Arcane © Riot Games & Fortiche</span>
              <span>&copy; {new Date().getFullYear()} CaitVi Hub</span>
            </div>
          </div>
        </div>
      </section>

    </main>

  </body>
</html>

<script>
  const scroller = document.getElementById('scroller');
  const sections = document.querySelectorAll('.section-panel');
  
  function updateParallax() {
    const scrollTop = scroller?.scrollTop ?? 0;
    const viewportHeight = window.innerHeight;
    
    sections.forEach((section, index) => {
      const sectionTop = index * viewportHeight;
      const offset = scrollTop - sectionTop;
      const progress = Math.max(-1, Math.min(1, offset / viewportHeight));
      
      const bg = section.querySelector('.parallax-bg') as HTMLElement;
      if (!bg) return;
      
      const type = section.getAttribute('data-parallax-type');
      
      switch(type) {
        case 'zoom-out': {
          const scale = 1.15 - (Math.abs(progress) * 0.1);
          const translateY = progress * 30;
          bg.style.transform = `scale(${scale}) translateY(${translateY}px)`;
          break;
        }
        case 'pan-right': {
          const translateX = progress * -40;
          bg.style.transform = `scale(1.1) translateX(${translateX}px)`;
          break;
        }
        case 'pan-left': {
          const translateX = progress * 40;
          bg.style.transform = `scale(1.1) translateX(${translateX}px)`;
          break;
        }
        case 'zoom-in': {
          const scale = 1 + (1 - Math.abs(progress)) * 0.15;
          bg.style.transform = `scale(${scale})`;
          break;
        }
      }
    });
  }
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.content-animate').forEach((el) => {
          el.classList.add('is-visible');
        });
      }
    });
  }, { root: scroller, threshold: 0.3 });

  sections.forEach(section => observer.observe(section));
  scroller?.addEventListener('scroll', updateParallax, { passive: true });
  updateParallax();
</script>

<style>
  /* Hero overlay — unified with home page */
  .hero-overlay {
    background: linear-gradient(
      to top,
      rgba(10, 6, 8, 0.95) 0%,
      rgba(10, 6, 8, 0.7) 25%,
      rgba(10, 6, 8, 0.2) 50%,
      transparent 70%
    );
  }

  .parallax-bg {
    will-change: transform;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .content-animate {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0.5s);
  }
  
  .content-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  #section-hero .content-animate {
    animation: heroReveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0.5s);
  }
  
  @keyframes heroReveal {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
